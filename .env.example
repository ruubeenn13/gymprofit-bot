# ============================================================
# Plantilla de variables de entorno de GymProBot.
# Copiar a `.env` (ignorado por git) y rellenar. En local se exportan a mano antes de
# arrancar; en Render se configuran en el dashboard (ver render.yaml). SPEC §9.
# NUNCA commitear el .env real ni ningún secreto.
# ============================================================

# --- Discord ---
DISCORD_TOKEN=

# --- BD del bot (Aiven MySQL, database gymprofit_bot) ---
DB_URL=jdbc:mysql://HOST:PUERTO/gymprofit_bot?sslMode=REQUIRED&useUnicode=true&characterEncoding=UTF-8
DB_USER=
DB_PASSWORD=

# --- API GymProFit ---
GYMPROFIT_API_URL=https://gymprofit-api.onrender.com/api
BOT_SERVICE_USER=
BOT_SERVICE_PASSWORD=

# --- Cifrado de datos (RGPD) ---
# Clave AES-256 (32 bytes en base64) para cifrar texto libre con posible dato personal
# (motivos de sanción, apodos previos). Genera una con Cifrador.generarClaveBase64() y
# GUÁRDALA a buen recaudo: si la pierdes, no podrás descifrar lo ya guardado.
# Vacío = cifrado deshabilitado (arranque degradado; los comandos que cifran avisan).
BOT_CRYPTO_KEY=

# --- Runtime ---
PORT=8080
TZ=Europe/Madrid
